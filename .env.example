# ─── App / Domain ─────────────────────────────────────────────
DOMAIN=yourdomain.com
CERTBOT_EMAIL=you@example.com

# ─── Django ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key-minimum-50-chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=replace-with-strong-password

# ─── AWS S3 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Set to True once S3 is configured:
USE_S3=False

# ─── GitHub Container Registry (on EC2 for pulling images) ────
GHCR_USER=your-github-username
GHCR_TOKEN=your-github-pat-with-read-packages-scope
